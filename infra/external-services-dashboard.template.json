{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Dashboard template for external services (non-Azure dependencies) with drill-down across metrics, logs, and traces"
  },
  "parameters": {
    "dashboardName": {
      "type": "string",
      "defaultValue": "external-services-observability"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "applicationInsightsResourceId": {
      "type": "string"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Portal/dashboards",
      "apiVersion": "2022-12-01-preview",
      "name": "[parameters('dashboardName')]",
      "location": "[parameters('location')]",
      "properties": {
        "lenses": {
          "0": {
            "order": 0,
            "parts": {
              "0": {
                "position": {
                  "x": 0,
                  "y": 0,
                  "rowSpan": 4,
                  "colSpan": 6
                },
                "metadata": {
                  "type": "Extension/AppInsightsExtension/PartType/AnalyticsPart",
                  "settings": {
                    "content": {
                      "Query": "dependencies | where target has 'fraud-api' or target has 'policy-api' | summarize total=count(), failed=countif(success==false), p95=percentile(duration, 95) by target, bin(timestamp, 5m) | render timechart",
                      "PartTitle": "External Service Health"
                    }
                  },
                  "inputs": [
                    {
                      "name": "ComponentId",
                      "value": "[parameters('applicationInsightsResourceId')]"
                    }
                  ]
                }
              },
              "1": {
                "position": {
                  "x": 6,
                  "y": 0,
                  "rowSpan": 4,
                  "colSpan": 6
                },
                "metadata": {
                  "type": "Extension/AppInsightsExtension/PartType/AnalyticsPart",
                  "settings": {
                    "content": {
                      "Query": "exceptions | where customDimensions['sourceSystem'] == 'external-service' | summarize count() by type, outerMessage | order by count_ desc | render table",
                      "PartTitle": "External Service Exceptions"
                    }
                  },
                  "inputs": [
                    {
                      "name": "ComponentId",
                      "value": "[parameters('applicationInsightsResourceId')]"
                    }
                  ]
                }
              },
              "2": {
                "position": {
                  "x": 0,
                  "y": 4,
                  "rowSpan": 4,
                  "colSpan": 12
                },
                "metadata": {
                  "type": "Extension/AppInsightsExtension/PartType/AnalyticsPart",
                  "settings": {
                    "content": {
                      "Query": "union requests, dependencies, traces, exceptions | where operation_Id == '{operationId}' | order by timestamp asc | project timestamp, itemType, name, target, duration, success, message",
                      "PartTitle": "Drill-down by Operation"
                    }
                  },
                  "inputs": [
                    {
                      "name": "ComponentId",
                      "value": "[parameters('applicationInsightsResourceId')]"
                    }
                  ]
                }
              }
            }
          }
        },
        "metadata": {
          "model": {
            "timeRange": {
              "value": {
                "relative": {
                  "duration": 24,
                  "timeUnit": 1
                }
              },
              "type": "MsPortalFx.Composition.Configuration.ValueTypes.TimeRange"
            },
            "filterLocale": {
              "value": "en-us"
            }
          }
        }
      }
    }
  ]
}
